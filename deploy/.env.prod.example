# Copy to .env on the droplet (same folder as docker-compose.prod.yml)

# GitHub Container Registry owner/org name
GHCR_OWNER=locobit
API_TAG=latest
WEB_TAG=latest

# DB
DB_NAME=managant
DB_USER=managant
DB_PASSWORD=managant
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT_HOST=3311

# Google
GOOGLE_CLIENT_ID=

# Frontend build-time config (GitHub Actions)
# Recommended: empty string to use same-origin (/api)
VITE_API_BASE=
VITE_GOOGLE_CLIENT_ID=
